{
  "manifest_version": 2,
  "name": "Form Filler",
  "version": "1.0.0",
  "description": "Fill form fields with configured default, custom, or random values.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Fill Forms"
  },
  "commands": {
    "fill-forms": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "MacCtrl+Shift+F"
      },
      "description": "Fill all form fields on the current page"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/fill.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
